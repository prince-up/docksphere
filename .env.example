# DockSphere Environment Configuration

# Database
MONGODB_URL=mongodb://localhost:27017/docksphere
MONGODB_DATABASE=docksphere

# Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-here
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# GitHub Integration
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_TLS_VERIFY=0

# Application Settings
APP_ENV=development
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# Nginx Configuration
NGINX_CONFIG_PATH=/etc/nginx/conf.d
NGINX_SSL_CERT_PATH=/etc/ssl/certs
NGINX_SSL_KEY_PATH=/etc/ssl/private

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_PASSWORD=admin

# Email (Optional - for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/docksphere/app.log

# Security
CORS_ORIGINS=["http://localhost:3000", "https://docksphere.com"]
ALLOWED_HOSTS=["localhost", "127.0.0.1", "docksphere.com"]

# Deployment Settings
MAX_DEPLOYMENTS_PER_USER=10
CONTAINER_TIMEOUT=300
BUILD_TIMEOUT=600

# File Upload
MAX_UPLOAD_SIZE=100MB
UPLOAD_PATH=/tmp/docksphere/uploads

# Git Settings
GIT_CLONE_TIMEOUT=300
GIT_DEFAULT_BRANCH=main